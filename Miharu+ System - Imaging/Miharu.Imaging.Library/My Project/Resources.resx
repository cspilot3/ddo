  <data name="GetExpedientes" xml:space="preserve">
    <value>SELECT DISTINCT Llave.fk_Entidad
		,Entidad.Nombre_Entidad
		,Llave.fk_Proyecto
		,Proyecto.Nombre_Proyecto
		,Esquema.id_Esquema
		,Esquema.Nombre_Esquema
		,ImagingFile.fk_Expediente 
        ,ImagingFile.fk_Folder
		,ImagingFile.fk_File
		,ImagingFile.id_Version
		,ImagingFile.File_Unique_Identifier
        ,Llave.Llave_01 + ISNULL( '_' + Llave.Llave_02,'') + '_' + CAST(fk_Tipologia AS VARCHAR(100)) + '_' +  CAST(ImagingFile.fk_File AS VARCHAR(100)) AS Nombre_Imagen_File
		,ImagingFile.Folios_Documento_File
		,ImagingFile.Tamaño_Imagen_File
		,ProcessFile.fk_Documento
		,Documento.Nombre_Documento
		,0 AS fk_Grupo
		,Llave.Llave_01 AS Llave_01
		,Llave.Llave_02 AS Llave_02
		,Documento.fk_Tipologia 
		,CASE	WHEN  File2.fk_Expediente IS NOT NULL THEN 2  
				WHEN  File3.fk_Expediente IS NOT NULL THEN 3  
				WHEN  File4.fk_Expediente IS NOT NULL THEN 4 
				WHEN  File5.fk_Expediente IS NOT NULL THEN 5 
		END AS fk_ServidorStorage
		,PFolder.Cbarras_Folder
		INTO #TempExpedientes
		FROM ##TempCarpetas T 
		INNER JOIN	[DB_Miharu.Core].Process.TBL_Folder PFolder WITH(NOLOCK)
				ON	T.Carpeta = PFolder.Cbarras_Folder
		INNER JOIN	[DB_Miharu.Core].[Process].[TBL_Expediente_Llave_Linea] Llave WITH(NOLOCK)
				ON	PFolder.fk_Expediente = Llave.fk_Expediente  
		INNER JOIN	[DB_Miharu.Core].Process.TBL_File AS ProcessFile WITH(NOLOCK)
				ON	PFolder.fk_Expediente = ProcessFile.fk_Expediente 
				AND PFolder.id_Folder = ProcessFile.fk_Folder 
		INNER JOIN	[DB_Miharu.Core].Imaging.TBL_File ImagingFile WITH(NOLOCK)
				ON	ImagingFile.fk_Expediente = ProcessFile.fk_Expediente
				AND ImagingFile.fk_Folder = ProcessFile.fk_Folder
				AND ImagingFile.fk_File = ProcessFile.id_File
		INNER JOIN	[DB_Miharu.Core].Process.TBL_File_Estado FE WITH(NOLOCK)
				ON	FE.fk_Expediente = ImagingFile.fk_Expediente
				AND FE.fk_Folder = ImagingFile.fk_Folder
				AND FE.fk_File = ImagingFile.fk_File
				AND FE.Modulo = 7
				AND FE.fk_Estado &gt;= 20               
		INNER JOIN	[DB_Miharu.Core].Config.TBL_Documento AS Documento WITH(NOLOCK)
				ON	ProcessFile.fk_Documento = Documento.id_Documento 
		INNER JOIN	[DB_Miharu.Archiving].Risk.TBL_File RFile WITH(NOLOCK)
				ON	RFile.fk_Expediente = ImagingFile.fk_Expediente
				AND RFile.fk_Folder = ImagingFile.fk_Folder
				AND RFile.id_File = ImagingFile.fk_File
		INNER JOIN	[DB_Miharu.Archiving].Risk.TBL_OT ROT WITH(NOLOCK)
				ON	ROT.id_OT = RFile.fk_OT
				AND	ROT.Fecha_OT &lt; '2019-07-09 23:59:59.999'
		INNER JOIN	[DB_Miharu.Core].Config.TBL_Esquema Esquema
				ON	Esquema.fk_Entidad = LLave.fk_Entidad
				AND Esquema.fk_Proyecto = Llave.fk_Proyecto
				AND Esquema.id_Esquema = Llave.fk_Esquema
		INNER JOIN	[DB_Miharu.Security_Core].Config.TBL_Entidad Entidad
				ON	Entidad.id_Entidad = Llave.fk_Entidad
		INNER JOIN	[DB_Miharu.Core].Config.TBL_Proyecto Proyecto
				ON	Proyecto.fk_Entidad = Entidad.id_Entidad
				AND	Proyecto.id_Proyecto = Llave.fk_Proyecto
		LEFT JOIN	[DB_Miharu.Imaging_Storage].Imaging.TBL_File File2 WITH(NOLOCK)
				ON	File2.fk_Expediente = ProcessFile.fk_Expediente 
				AND File2.fk_Folder = ProcessFile.fk_Folder 
				AND File2.fk_File = ProcessFile.id_File 
		LEFT JOIN	[Historico].[DB_Miharu.Imaging_Storage].Imaging.TBL_File File3 WITH(NOLOCK) 
				ON	File3.fk_Expediente = ProcessFile.fk_Expediente 
				AND File3.fk_Folder = ProcessFile.fk_Folder 
				AND File3.fk_File = ProcessFile.id_File 
		LEFT JOIN	[Historico].[DB_Miharu.Imaging_Storage_2].Imaging.TBL_File File4 WITH(NOLOCK)   
				ON	File4.fk_Expediente = ProcessFile.fk_Expediente 
				AND File4.fk_Folder = ProcessFile.fk_Folder 
				AND File4.fk_File = ProcessFile.id_File 
		LEFT JOIN	[Historico].[DB_Miharu.Imaging_Storage_3].Imaging.TBL_File File5 WITH(NOLOCK)   
				ON	File5.fk_Expediente = ProcessFile.fk_Expediente 
				AND File5.fk_Folder = ProcessFile.fk_Folder 
				AND File5.fk_File = ProcessFile.id_File 

        UPDATE #TempExpedientes 
        SET fk_ServidorStorage = 1 
        WHERE(fk_ServidorStorage IS NULL) 

		SELECT  * 
		FROM #TempExpedientes 


        
		DROP TABLE #TempExpedientes</value>
  </data>
